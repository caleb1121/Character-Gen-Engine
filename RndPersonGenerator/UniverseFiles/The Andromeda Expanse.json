  "BioTemplates": {
    "1_Origin_and_Identity": [
      {
        "Text": "Designated {Full}, {Subject} is a registered {Classification} currently operating in the Andromeda system. Originally hailing from {Homeworld}, {Subject} left the core worlds behind for a life in the fringes.",
        "Requires": "Military",
        "Weight": 10
      },
      {
        "Text": "Known on the rain-slicked streets as '{Nick}', {Subject} makes a precarious living as a {Occupation} in the {District}.",
        "Requires": "Civilian",
        "Weight": 20
      },
      {
        "Text": "There are few names in the criminal underworld as feared as {Full}. Operating under the alias '{Nick}', {Subject} is a ruthless {Classification}.",
        "Requires": "Outlaw",
        "Weight": 20
      },
      {
        "Text": "The {Full} is a {Nickname} class vessel. Built by {Manufacturer}, it was designed to conquer the cold expanse of the void.",
        "Requires": "Capital_Ship",
        "Weight": 20
      },
      {
        "Text": "Sleek and deadly, {Full} is a {Nickname} class fighter craft. Manufactured by {Manufacturer}, it is built for pure dogfighting superiority.",
        "Requires": "Fighter",
        "Weight": 20
      },
      {
        "Text": "Deep in the uncharted sectors lies {Full}, colloquially known to smugglers as '{Nick}'. It is a vast {Classification} orbiting a dying star.",
        "Requires": "Planet",
        "Weight": 20
      },
      {
        "Text": "{Full}, often referred to simply as '{Nick}', is a massive {Classification} that spans multiple star systems.",
        "Requires": "Organization",
        "Weight": 20
      }
    ],
    "2_Loadout_and_Gear": [
      {
        "Text": "In combat, {Subject} relies heavily on {Possessive} {Primary Weapon}, keeping a {Secondary Sidearm} holstered just in case. {Possessive} body is protected by {Armor Class}.",
