      }
    ],
    "2_Deeds": [
      {
        "Text": "{Nick} once wrestled a mountain troll to the ground, earning {Possessive} title through raw power.",
        "MinStatName": "Strength",
        "MinStatValue": 17,
        "Weight": 50
      },
      {
        "Text": "{Nick} is whispered to be a genius, having memorized the Forbidden Grimoires before age ten.",
        "MinStatName": "Intelligence",
        "MinStatValue": 17,
        "Weight": 50
      },
      {
        "Text": "Blades shatter against {Nick}'s form; {Subject} once walked through a storm of arrows without a scratch.",
        "MinStatName": "Constitution",
        "MinStatValue": 18,
        "Weight": 50
      },
      {
        "Text": "Travelers know {Nick} as a survivor who can endure any hardship.",
        "Weight": 10
      }
    ],
    "3_Artifact": [
      {
        "Text": "{Subject} carries {Possessive} {Signature Weapon} with a solemn vow to restore {Possessive} family name.",
        "Requires": "Relic-Bearer",
        "Weight": 50
      },
      {
        "Text": "Few have looked upon {Possessive} {Focus Tool} and lived to tell of its flickering aetheric glow.",
        "Requires": "Arcane-Gift",
        "Weight": 10
      },
      {
        "Text": "With {Possessive} {Physical Mutation}, {Subject} strikes terror into the hearts of any who dare cross {Possessive} path.",
        "Requires": "Monstrous",
        "Weight": 10
      }
    ],
    "4_Destiny": [
      {
        "Text": "Though the road is long, {Subject} knows that {Possessive} high spirit will lead {Object} to victory.",
        "Requires": "Noble-Blood",
        "Weight": 10
      },
      {
        "Text": "The world fears {Possessive} power, but {Subject} uses it to seek the truth.",
        "Requires": "Arcane-Gift",
        "Weight": 10
      },
      {
        "Text": "In the end, {Nick} will either save the realms or be the spark that burns them to ash.",
        "Weight": 10
      }
